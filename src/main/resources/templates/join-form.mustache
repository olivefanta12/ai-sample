<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>회원가입 - 주소 검색 샘플</title>
</head>
<body>

<h1>회원가입 (주소 연동 API)</h1>

<form action="/join" method="post">
    <!-- 기본 회원 정보 -->
    <input type="text" name="username" placeholder="아이디" required><br>
    <input type="password" name="password" placeholder="비밀번호" required><br>
    <input type="email" name="email" placeholder="이메일" required><br>
    <hr>
    
    <!-- 주소 입력란 -->
    <input type="text" id="postcode" name="postcode" placeholder="우편번호" readonly>
    <input type="button" onclick="execDaumPostcode()" value="우편번호 찾기"><br>

    <!-- 기본 주소: 수동 입력 금지(readonly) -->
    <input type="text" id="address" name="address" placeholder="주소" size="40" readonly><br>

    <!-- 상세 주소: 수동 입력 허용 -->
    <input type="text" id="detailAddress" name="detailAddress" placeholder="상세주소">
    
    <!-- 참고 항목: 건물명 등 부가 정보 (readonly) -->
    <input type="text" id="extraAddress" name="extraAddress" placeholder="참고항목" readonly><br>

    <hr>
    <button type="submit">가입완료</button>
</form>

<!-- 카카오(다음) 우편번호 API 라이브러리 로드 -->
<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>

<script>
    function execDaumPostcode() {
        new daum.Postcode({
            oncomplete: function(data) {
                // 사용자가 선택한 주소 타입에 따라 변수 결정
                let addr = ''; // 주소 변수
                let extraAddr = ''; // 참고항목 변수

                // 도로명 주소 선택 시 (핵심 로직)
                if (data.userSelectedType === 'R') {
                    addr = data.roadAddress;
                } else { // 지번 주소 선택 시
                    addr = data.jibunAddress;
                }

                // 부가 정보 조립 (건물명, 동 이름 등)
                if(data.userSelectedType === 'R'){
                    if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)){
                        extraAddr += data.bname;
                    }
                    if(data.buildingName !== '' && data.apartment === 'Y'){
                        extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
                    }
                    if(extraAddr !== ''){
                        extraAddr = ' (' + extraAddr + ')';
                    }
                    document.querySelector("#extraAddress").value = extraAddr;
                } else {
                    document.querySelector("#extraAddress").value = '';
                }

                // 각 필드에 데이터 매핑
                document.querySelector('#postcode').value = data.zonecode;
                document.querySelector("#address").value = addr;
                
                // 상세주소 필드로 포커스 이동 (사용자 입력 유도)
                document.querySelector("#detailAddress").focus();
            }
        }).open();
    }
</script>

</body>
</html>
